@page "/users"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Usuarios</PageTitle>

<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Usuarios internos</h1>
        <p class="text-muted mb-0">Gestioná accesos, roles y hospedaje por defecto de la cuenta.</p>
    </div>
    <button class="btn btn-primary" @onclick="NewUser">
        <i class="bi bi-person-plus me-1"></i> Nuevo usuario
    </button>
</div>

<div class="card mb-3">
    <div class="card-body pt-3">
        @if (!string.IsNullOrWhiteSpace(_pageError))
        {
            <div class="alert alert-danger">@_pageError</div>
        }
        @if (!_loaded)
        {
            <EmptyState Title="Cargando usuarios"
                        Description="Estamos trayendo los accesos internos y sus hospedajes por defecto."
                        Icon="bi-people" />
        }
        else if (!_items.Any())
        {
            <EmptyState Title="Todavía no hay usuarios internos"
                        Description="Creá el primer usuario para delegar operación o recepción."
                        Icon="bi-person-plus">
                <button class="btn btn-primary" @onclick="NewUser"><i class="bi bi-person-plus me-1"></i> Nuevo usuario</button>
            </EmptyState>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="card-title mb-1">Usuarios de la cuenta</h5>
                    <div class="small text-muted">Accesos internos activos e inactivos con su rol operativo.</div>
                </div>
                <span class="ui-badge ui-badge-neutral">@_items.Count</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Rol</th>
                            <th>Hospedaje por defecto</th>
                            <th>Último acceso</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td>
                                <strong>@item.DisplayName</strong>
                                <div class="small text-muted">@item.Email</div>
                            </td>
                            <td><span class="badge bg-info-subtle text-dark">@RoleLabel(item.Role)</span></td>
                            <td>@(item.DefaultPropertyName ?? "Sin definir")</td>
                            <td>@(item.LastLoginAtUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin acceso")</td>
                            <td><StatusBadge IsActive="@item.IsActive" /></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(item)">Editar</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(item)">@(item.IsActive ? "Desactivar" : "Activar")</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (_showForm)
{
    <div class="card">
        <div class="card-body pt-3">
            <h5 class="card-title">@(_form.UserId is null ? "Nuevo usuario" : "Editar usuario")</h5>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }
            <div class="row g-3">
                <div class="col-md-6"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Nombre" /></div>
                <div class="col-md-6"><label class="form-label">Apellido</label><input class="form-control" @bind="_form.Apellido" /></div>
                <div class="col-md-6"><label class="form-label">Email</label><input class="form-control" @bind="_form.Email" /></div>
                <div class="col-md-3"><label class="form-label">Rol</label><select class="form-select" @bind="_form.Role">@foreach (var role in Enum.GetValues<InternalUserRole>()){<option value="@role">@RoleLabel(role)</option>}</select></div>
                <div class="col-md-3"><label class="form-label">Activo</label><select class="form-select" @bind="_form.IsActive"><option value="true">Sí</option><option value="false">No</option></select></div>
                <div class="col-md-6"><label class="form-label">Hospedaje por defecto</label><select class="form-select" @bind="_form.DefaultPropertyId"><option value="">Sin definir</option>@foreach(var p in _properties){<option value="@p.Id">@p.Name</option>}</select></div>
                <div class="col-md-6">
                    <label class="form-label">@(_form.UserId is null ? "Password temporal" : "Nueva contraseña temporal")</label>
                    <div class="input-group">
                        <input class="form-control" type="@(_showPassword ? "text" : "password")" autocomplete="new-password" @bind="_form.Password" />
                        <button type="button" class="btn btn-outline-secondary" @onclick="TogglePasswordVisibility">@(_showPassword ? "Ocultar" : "Ver")</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="GeneratePasswordForForm">Generar</button>
                    </div>
                    <div class="form-text">
                        @if (_form.UserId is null)
                        {
                            <span>Se crea con una clave temporal editable para evitar usar una contraseña fija repetida.</span>
                        }
                        else
                        {
                            <span>Opcional. Si completás este campo, la contraseña actual del usuario se reemplaza por una nueva temporal.</span>
                        }
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" disabled="@_saving" @onclick="Save">Guardar</button>
                <button class="btn btn-outline-secondary" disabled="@_saving" @onclick="Cancel">Cancelar</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool _showForm;
    private bool _showPassword;
    private bool _saving;
    private string? _error;
    private string? _pageError;
    private List<AccountUserListItemDto> _items = new();
    private List<PropertyListItemDto> _properties = new();
    private UpsertAccountUserCommand _form = new(null, "", "", "", true, InternalUserRole.Reception, null, GenerateTemporaryPassword());

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _pageError = null;

        var users = await Api.GetAsync<AppResult<List<AccountUserListItemDto>>>("api/saas/users");
        var props = await Api.GetAsync<AppResult<List<PropertyListItemDto>>>("api/properties/mine");

        if (users?.Success != true || props?.Success != true)
        {
            _items = new();
            _properties = new();
            _pageError = users?.Message ?? props?.Message ?? "No se pudo cargar la información de usuarios.";
            _loaded = true;
            return;
        }

        _items = users.Data ?? new();
        _properties = props.Data ?? new();
        _loaded = true;
    }

    private void NewUser()
    {
        _error = null;
        _showPassword = false;
        _form = new UpsertAccountUserCommand(null, "", "", "", true, InternalUserRole.Reception, null, GenerateTemporaryPassword());
        _showForm = true;
    }

    private void Edit(AccountUserListItemDto item)
    {
        _error = null;
        _showPassword = false;
        _form = new UpsertAccountUserCommand(item.UserId, item.Nombre, item.Apellido, item.Email, item.IsActive, item.Role, item.DefaultPropertyId, null);
        _showForm = true;
    }

    private async Task Save()
    {
        _error = null;
        _saving = true;

        AppResult? response;
        if (_form.UserId is null)
            response = await Api.PostJsonAsync<AppResult, UpsertAccountUserCommand>("api/saas/users", _form);
        else
            response = await Api.PutAsync<UpsertAccountUserCommand, AppResult>($"api/saas/users/{_form.UserId}", _form);

        if (response?.Success != true)
        {
            _error = response?.Message ?? "No se pudo guardar el usuario.";
            _saving = false;
            return;
        }

        _showForm = false;
        await LoadAsync();
        Api.Toast(string.IsNullOrWhiteSpace(_form.Password) ? "Usuario guardado correctamente." : "Usuario guardado y contraseña temporal actualizada.");
        _saving = false;
    }

    private async Task Toggle(AccountUserListItemDto item)
    {
        _pageError = null;
        var action = item.IsActive ? "desactivar" : "activar";
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Querés {action} al usuario {item.DisplayName}?");
        if (!confirmed)
            return;

        var response = await Api.PostJsonAsync<AppResult, object>($"api/saas/users/{item.UserId}/status", new { isActive = !item.IsActive });
        if (response?.Success != true)
        {
            _pageError = response?.Message ?? "No se pudo actualizar el estado del usuario.";
            return;
        }

        await LoadAsync();
    }

    private void Cancel()
    {
        _showForm = false;
        _showPassword = false;
        _error = null;
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void GeneratePasswordForForm() => _form.Password = GenerateTemporaryPassword();

    private static string RoleLabel(InternalUserRole role) => role switch
    {
        InternalUserRole.Owner => "Propietario",
        InternalUserRole.Admin => "Administrador",
        InternalUserRole.Reception => "Recepción",
        InternalUserRole.Operations => "Operaciones",
        _ => role.ToString()
    };

    private static string GenerateTemporaryPassword()
        => $"Tmp{Guid.NewGuid():N}"[..12] + "!";
}
