@page "/properties/{PropertyId:int}/features"
@using GestAI.Web.Dtos
@inject ApiClient Api

<PageTitle>Configuración funcional</PageTitle>

<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Configuración funcional</h1>
        <p class="text-muted mb-0">Activá o desactivá módulos del sistema para este hospedaje.</p>
    </div>
    <button class="btn btn-primary" @onclick="Save">Guardar cambios</button>
</div>

@if (_settings is null)
{
    <p>Cargando...</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    @foreach (var group in Groups)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@group.Title</h5>
                @foreach (var item in group.Items)
                {
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" checked="@item.Getter()" @onchange="e => item.Setter((bool)e.Value!)" />
                        <label class="form-check-label fw-semibold">@item.Label</label>
                        <div class="small text-muted">@item.Description</div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public int PropertyId { get; set; }
    private PropertyFeatureSettingsDto? _settings;
    private string? _message;

    protected override async Task OnParametersSetAsync()
    {
        var res = await Api.GetAsync<AppResult<PropertyFeatureSettingsDto>>($"api/properties/{PropertyId}/feature-settings");
        _settings = res?.Data;
    }

    private IReadOnlyList<(string Title, List<(string Label, string Description, Func<bool> Getter, Action<bool> Setter)> Items)> Groups
        => _settings is null
            ? []
            :
            [
                ("Operación", new List<(string, string, Func<bool>, Action<bool>)>
                {
                    ("Housekeeping", "Limpieza y tareas post checkout.", () => _settings.EnableHousekeeping, v => _settings.EnableHousekeeping = v),
                    ("Agenda", "Vista de check-ins y check-outs.", () => _settings.EnableAgenda, v => _settings.EnableAgenda = v),
                    ("Modo huésped simple", "Pide solo datos mínimos del huésped.", () => _settings.UseSimpleGuestMode, v => _settings.UseSimpleGuestMode = v)
                }),
                ("Comercial", new List<(string, string, Func<bool>, Action<bool>)>
                {
                    ("Cotizador", "Cotización de estadías.", () => _settings.EnableQuotes, v => _settings.EnableQuotes = v),
                    ("Cotizaciones guardadas", "Guardar y convertir cotizaciones.", () => _settings.EnableSavedQuotes, v => _settings.EnableSavedQuotes = v),
                    ("Promociones", "Reglas promocionales en pricing.", () => _settings.EnablePromotions, v => _settings.EnablePromotions = v),
                    ("Tarifas avanzadas", "Rate plans, temporadas y rangos de fecha.", () => _settings.EnableAdvancedRates, v => _settings.EnableAdvancedRates = v),
                    ("Venta directa", "Flujo de reservas públicas directas.", () => _settings.EnableDirectBooking, v => _settings.EnableDirectBooking = v)
                }),
                ("Finanzas", new List<(string, string, Func<bool>, Action<bool>)>
                {
                    ("Pagos", "Registro y consulta de pagos.", () => _settings.EnablePayments, v => _settings.EnablePayments = v)
                }),
                ("Distribución", new List<(string, string, Func<bool>, Action<bool>)>
                {
                    ("Sync calendarios externos", "Conexiones y sincronización OTA.", () => _settings.EnableExternalCalendarSync, v => _settings.EnableExternalCalendarSync = v)
                }),
                ("Gestión", new List<(string, string, Func<bool>, Action<bool>)>
                {
                    ("Reportes", "Paneles de ocupación e ingresos.", () => _settings.EnableReports, v => _settings.EnableReports = v),
                    ("Plantillas", "Mensajería predefinida.", () => _settings.EnableTemplates, v => _settings.EnableTemplates = v),
                    ("Vista de auditoría", "Acceso visual al historial de auditoría.", () => _settings.EnableAuditView, v => _settings.EnableAuditView = v)
                })
            ];

    private async Task Save()
    {
        if (_settings is null)
            return;

        var cmd = new UpdatePropertyFeatureSettingsCommand(
            PropertyId,
            _settings.EnableHousekeeping,
            _settings.EnableAgenda,
            _settings.EnableQuotes,
            _settings.EnableSavedQuotes,
            _settings.EnablePromotions,
            _settings.EnableAdvancedRates,
            _settings.EnablePayments,
            _settings.EnableDirectBooking,
            _settings.EnableExternalCalendarSync,
            _settings.EnableReports,
            _settings.EnableTemplates,
            _settings.EnableAuditView,
            _settings.UseSimpleGuestMode);

        var res = await Api.PutAsync<UpdatePropertyFeatureSettingsCommand, AppResult<PropertyFeatureSettingsDto>>($"api/properties/{PropertyId}/feature-settings", cmd);
        if (res?.Success == true && res.Data is not null)
        {
            _settings = res.Data;
            _message = "Configuración funcional actualizada.";
        }
        else
        {
            _message = res?.Message ?? "No se pudo guardar la configuración.";
        }
    }
}
