@page "/properties/{PropertyId:int}/features"
@using GestAI.Web.Dtos
@using GestAI.Web.Helpers
@inject ApiClient Api
@inject GestAI.Web.Service.PropertyFeatureState FeatureState

<PageTitle>Configuración funcional</PageTitle>

<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Configuración funcional</h1>
        <p class="text-muted mb-0">Activá o desactivá módulos del sistema para este hospedaje.</p>
    </div>
    <button class="btn btn-primary" @onclick="Save">Guardar cambios</button>
</div>

@if (_settings is null)
{
    <p>Cargando...</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    @foreach (var group in Groups)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@group.Title</h5>
                @foreach (var item in group.Items)
                {
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" checked="@item.Getter()" disabled="@item.Disabled" @onchange="e => item.Setter((bool)e.Value!)" />
                        <label class="form-check-label fw-semibold">@item.Label</label>
                        <div class="small text-muted">@item.Description</div>
                        @if (!string.IsNullOrWhiteSpace(item.Helper))
                        {
                            <div class="small text-secondary">@item.Helper</div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public int PropertyId { get; set; }
    private PropertyFeatureSettingsDto? _settings;
    private CurrentUserAccessDto? _access;
    private string? _message;

    protected override async Task OnParametersSetAsync()
    {
        _settings = await FeatureState.EnsureAsync(PropertyId);
        var access = await Api.GetAsync<AppResult<CurrentUserAccessDto>>("api/saas/me/access");
        _access = access?.Success == true ? access.Data : null;
    }

    private IReadOnlyList<(string Title, List<(string Label, string Description, string? Helper, bool Disabled, Func<bool> Getter, Action<bool> Setter)> Items)> Groups
        => _settings is null
            ? []
            :
            [
                ("Operación", new List<(string, string, string?, bool, Func<bool>, Action<bool>)>
                {
                    ("Mostrar módulo de limpieza", "Incluye tablero y tareas de housekeeping.", GetModuleHelper(nameof(PropertyFeatureSettingsDto.EnableHousekeeping)), IsModuleGovernedFeatureDisabled(nameof(PropertyFeatureSettingsDto.EnableHousekeeping)), () => _settings.EnableHousekeeping, v => _settings.EnableHousekeeping = v),
                    ("Mostrar agenda operativa", "Vista diaria de check-ins y check-outs.", null, false, () => _settings.EnableAgenda, v => _settings.EnableAgenda = v),
                    ("Usar modo simple de huéspedes", "Simplifica formularios y prioriza datos mínimos.", null, false, () => _settings.UseSimpleGuestMode, v => _settings.UseSimpleGuestMode = v)
                }),
                ("Comercial", new List<(string, string, string?, bool, Func<bool>, Action<bool>)>
                {
                    ("Mostrar cotizador", "Cotización comercial por estadía.", null, false, () => _settings.EnableQuotes, OnQuotesChanged),
                    ("Permitir cotizaciones guardadas", "Guardar propuestas y convertir a reserva.", _settings.EnableQuotes ? null : "Requiere mantener activo el cotizador.", !_settings.EnableQuotes, () => _settings.EnableSavedQuotes, v => _settings.EnableSavedQuotes = v),
                    ("Aplicar promociones", "Descuentos y reglas comerciales.", GetModuleHelper(nameof(PropertyFeatureSettingsDto.EnablePromotions)), IsModuleGovernedFeatureDisabled(nameof(PropertyFeatureSettingsDto.EnablePromotions)), () => _settings.EnablePromotions, v => _settings.EnablePromotions = v),
                    ("Usar tarifas avanzadas", "Temporadas y rangos específicos por fecha.", GetModuleHelper(nameof(PropertyFeatureSettingsDto.EnableAdvancedRates)), IsModuleGovernedFeatureDisabled(nameof(PropertyFeatureSettingsDto.EnableAdvancedRates)), () => _settings.EnableAdvancedRates, v => _settings.EnableAdvancedRates = v),
                    ("Habilitar venta directa", "Flujos públicos de reserva directa.", null, false, () => _settings.EnableDirectBooking, v => _settings.EnableDirectBooking = v)
                }),
                ("Finanzas", new List<(string, string, string?, bool, Func<bool>, Action<bool>)>
                {
                    ("Permitir registrar pagos", "Módulo de cobros y saldo.", GetModuleHelper(nameof(PropertyFeatureSettingsDto.EnablePayments)), IsModuleGovernedFeatureDisabled(nameof(PropertyFeatureSettingsDto.EnablePayments)), () => _settings.EnablePayments, v => _settings.EnablePayments = v)
                }),
                ("Distribución", new List<(string, string, string?, bool, Func<bool>, Action<bool>)>
                {
                    ("Sincronizar calendarios externos", "Conexiones OTA e importación iCal.", null, false, () => _settings.EnableExternalCalendarSync, v => _settings.EnableExternalCalendarSync = v)
                }),
                ("Gestión", new List<(string, string, string?, bool, Func<bool>, Action<bool>)>
                {
                    ("Mostrar reportes", "Métricas de ocupación e ingresos.", GetModuleHelper(nameof(PropertyFeatureSettingsDto.EnableReports)), IsModuleGovernedFeatureDisabled(nameof(PropertyFeatureSettingsDto.EnableReports)), () => _settings.EnableReports, v => _settings.EnableReports = v),
                    ("Usar plantillas", "Mensajes predefinidos para operación.", null, false, () => _settings.EnableTemplates, v => _settings.EnableTemplates = v),
                    ("Mostrar vista de auditoría", "Consulta visual de eventos auditados.", null, false, () => _settings.EnableAuditView, v => _settings.EnableAuditView = v)
                })
            ];

    private void OnQuotesChanged(bool value)
    {
        if (_settings is null)
            return;

        _settings.EnableQuotes = value;
        if (!value)
            _settings.EnableSavedQuotes = false;
    }

    private bool IsModuleGovernedFeatureDisabled(string featureKey)
    {
        var requiredModule = PropertyFeatureModulePolicy.GetRequiredModule(featureKey);
        return requiredModule.HasValue && !HasModule(requiredModule.Value);
    }

    private string? GetModuleHelper(string featureKey)
    {
        var requiredModule = PropertyFeatureModulePolicy.GetRequiredModule(featureKey);
        if (!requiredModule.HasValue || HasModule(requiredModule.Value))
            return null;

        return $"Requiere acceso habilitado al módulo {GetModuleLabel(requiredModule.Value)} para esta cuenta.";
    }

    private bool HasModule(SaasModule module)
        => _access?.Modules?.Any(x => x.Module == module && x.Allowed) ?? false;

    private static string GetModuleLabel(SaasModule module)
        => module switch
        {
            SaasModule.Rates => "Tarifas",
            SaasModule.Promotions => "Promociones",
            SaasModule.Payments => "Pagos",
            SaasModule.Housekeeping => "Housekeeping",
            SaasModule.Reports => "Reportes",
            _ => module.ToString()
        };

    private async Task Save()
    {
        if (_settings is null)
            return;

        var cmd = new UpdatePropertyFeatureSettingsCommand(
            PropertyId,
            _settings.EnableHousekeeping,
            _settings.EnableAgenda,
            _settings.EnableQuotes,
            _settings.EnableSavedQuotes,
            _settings.EnablePromotions,
            _settings.EnableAdvancedRates,
            _settings.EnablePayments,
            _settings.EnableDirectBooking,
            _settings.EnableExternalCalendarSync,
            _settings.EnableReports,
            _settings.EnableTemplates,
            _settings.EnableAuditView,
            _settings.UseSimpleGuestMode);

        var res = await Api.PutAsync<UpdatePropertyFeatureSettingsCommand, AppResult<PropertyFeatureSettingsDto>>($"api/properties/{PropertyId}/feature-settings", cmd);
        if (res?.Success == true && res.Data is not null)
        {
            _settings = res.Data;
            await FeatureState.RefreshAsync(PropertyId);
            _message = "Configuración funcional actualizada. Los cambios ya fueron aplicados en la navegación y módulos del hospedaje.";
        }
        else
        {
            _message = res?.Message ?? "No se pudo guardar la configuración.";
        }
    }
}
