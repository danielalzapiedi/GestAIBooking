@page "/quotes/{PropertyId:int}/saved"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject NavigationManager Nav
@inject GestAI.Web.Service.PropertyFeatureState FeatureState

<PageTitle>Cotizaciones guardadas</PageTitle>

@if (!_featureChecked)
{
    <EmptyState Title="Cargando configuración" Description="Estamos validando las funciones habilitadas para este hospedaje." Icon="bi-hourglass-split" />
}
else if (!_savedQuotesEnabled)
{
    <FeatureDisabledState PropertyId="@PropertyId"
                          FeatureName="Las cotizaciones guardadas" />
}
else
{
<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Cotizaciones guardadas</h1>
        <p class="text-muted mb-0">Reutilizá propuestas y convertí cotizaciones en reservas.</p>
    </div>
    <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo($"/quotes/{PropertyId}")'>Volver al cotizador</button>
</div>

<div class="card mb-3"><div class="card-body pt-3"><div class="row g-2">
    <div class="col-md-6"><input class="form-control" placeholder="Buscar por huésped, email o token" @bind="_search" /></div>
    <div class="col-md-3"><select class="form-select" @bind="_status"><option value="">Todos los estados</option>@foreach (var st in Enum.GetValues<SavedQuoteStatus>()){<option value="@st">@st</option>}</select></div>
    <div class="col-md-3"><button class="btn btn-primary w-100" @onclick="Load">Buscar</button></div>
</div></div></div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
}

<div class="card"><div class="card-body pt-3">
@if (!_loaded)
{
    <EmptyState Title="Cargando información" Description="Estamos trayendo los datos de esta pantalla." Icon="bi-hourglass-split" />
}
else if (!_items.Any())
{
    <EmptyState Title="No hay cotizaciones guardadas" Description="Guardá una cotización desde el cotizador para reutilizarla después." Icon="bi-journal-text" />
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Creada</th><th>Huésped</th><th>Unidad</th><th>Estadía</th><th>Total</th><th>Estado</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td><strong>@(item.GuestName ?? "Sin nombre")</strong><div class="small text-muted">@(item.GuestEmail ?? item.PublicToken)</div></td>
                    <td>@(item.UnitName ?? "Sin unidad")</td>
                    <td>@item.CheckInDate.ToString("dd/MM") - @item.CheckOutDate.ToString("dd/MM")<div class="small text-muted">@item.Adults adult. · @item.Children niños</div></td>
                    <td><strong>@item.TotalAmount.ToString("0.00")</strong><div class="small text-success">Seña @item.SuggestedDepositAmount.ToString("0.00")</div></td>
                    <td><StatusBadge Text="@item.Status.ToString()" CssClass="@(item.Status == SavedQuoteStatus.Converted ? "ui-badge ui-badge-success" : "ui-badge ui-badge-neutral")" /></td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="(() => Select(item))">Ver</button>
                        @if (item.Status != SavedQuoteStatus.Converted)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="(() => OpenConvertModal(item))">Convertir</button>
                        }
                        else if (item.CreatedBookingId.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick='() => Nav.NavigateTo($"/bookings/{PropertyId}/{item.CreatedBookingId.Value}")'>Ir a reserva</button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
</div></div>

@if (_selected is not null)
{
    <div class="card mt-3"><div class="card-body">
        <h5 class="card-title">Detalle de cotización</h5>
        <div class="row g-3">
            <div class="col-md-3"><div class="small text-muted">Unidad</div><div class="fw-bold">@(_selected.UnitName ?? "-")</div></div>
            <div class="col-md-3"><div class="small text-muted">Tarifa base</div><div class="fw-bold">@_selected.BaseAmount.ToString("0.00")</div></div>
            <div class="col-md-3"><div class="small text-muted">Promociones</div><div class="fw-bold text-success">- @_selected.PromotionsAmount.ToString("0.00")</div></div>
            <div class="col-md-3"><div class="small text-muted">Total</div><div class="fw-bold">@_selected.TotalAmount.ToString("0.00")</div></div>
        </div>
        @if (!string.IsNullOrWhiteSpace(_selected.AppliedPromotionNames))
        {
            <div class="mt-3"><StatusBadge Text="@_selected.AppliedPromotionNames" CssClass="ui-badge ui-badge-success" /></div>
        }
        @if (!string.IsNullOrWhiteSpace(_selected.Summary))
        {
            <div class="mt-3 alert alert-info mb-0">@_selected.Summary</div>
        }
    </div></div>
    }
}

@if (_convertModalOpen && _quoteToConvert is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Convertir cotización a reserva</h5>
                    <button type="button" class="btn-close" @onclick="CloseConvertModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <div><strong>Cotización:</strong> @_quoteToConvert.PublicToken</div>
                        <div><strong>Unidad:</strong> @(_quoteToConvert.UnitName ?? "Sin unidad")</div>
                        <div><strong>Estadía:</strong> @_quoteToConvert.CheckInDate.ToString("dd/MM/yyyy") al @_quoteToConvert.CheckOutDate.ToString("dd/MM/yyyy")</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_convertError))
                    {
                        <div class="alert alert-danger">@_convertError</div>
                    }

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Buscar huésped existente</label>
                            <input class="form-control" value="@_convertGuestQuery" @oninput="SearchGuestsForConvert" placeholder="Buscar por nombre, teléfono o email" />
                        </div>

                        @if (_convertGuestResults.Count > 0)
                        {
                            <div class="col-12">
                                <div class="list-group">
                                    @foreach (var guest in _convertGuestResults)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action" @onclick="(() => SelectConvertGuest(guest))">
                                            <div class="d-flex justify-content-between">
                                                <div>
                                                    <strong>@guest.FullName</strong>
                                                    <div class="small text-muted">@guest.Phone @guest.Email</div>
                                                </div>
                                                <span class="badge bg-primary">Seleccionar</span>
                                            </div>
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (_convertGuestId > 0)
                        {
                            <div class="col-12">
                                <div class="alert alert-success mb-0">Huésped seleccionado: <strong>@_convertGuestSelectedName</strong></div>
                            </div>
                        }

                        <div class="col-12"><hr class="my-1" /></div>

                        <div class="col-12">
                            <div class="fw-semibold">O crear un huésped rápido</div>
                            <div class="small text-muted">Útil si la cotización todavía no tiene un huésped registrado en el sistema.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Nombre completo</label>
                            <input class="form-control" @bind="_quickGuestFullName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teléfono</label>
                            <input class="form-control" @bind="_quickGuestPhone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" @bind="_quickGuestEmail" />
                        </div>
                        <div class="col-12">
                            <button class="btn btn-outline-primary" @onclick="CreateGuestForConvert">Crear huésped y seleccionar</button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseConvertModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ConfirmConvert" disabled="@(_converting || _convertGuestId <= 0)">
                        @(_converting ? "Convirtiendo..." : "Convertir a reserva")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int PropertyId { get; set; }
    private bool _featureChecked;
    private bool _savedQuotesEnabled = true;
    private List<SavedQuoteDto> _items = new();
    private SavedQuoteDto? _selected;
    private string? _search;
    private SavedQuoteStatus? _status;
    private bool _loaded;
    private string? _message;
    private bool _success;
    private bool _convertModalOpen;
    private bool _converting;
    private SavedQuoteDto? _quoteToConvert;
    private string _convertGuestQuery = string.Empty;
    private List<GuestSearchItemDto> _convertGuestResults = new();
    private int _convertGuestId;
    private string _convertGuestSelectedName = string.Empty;
    private string? _convertError;
    private string _quickGuestFullName = string.Empty;
    private string? _quickGuestPhone;
    private string? _quickGuestEmail;

    protected override async Task OnParametersSetAsync()
    {
        var settings = await FeatureState.EnsureAsync(PropertyId);
        _savedQuotesEnabled = settings?.EnableSavedQuotes ?? true;
        _featureChecked = true;
        if (_savedQuotesEnabled)
            await Load();
    }

    private async Task Load()
    {
        _loaded = false;
        var url = $"api/properties/{PropertyId}/quotes/saved";
        var qs = new List<string>();
        if (!string.IsNullOrWhiteSpace(_search)) qs.Add($"search={Uri.EscapeDataString(_search)}");
        if (_status.HasValue) qs.Add($"status={_status.Value}");
        if (qs.Any()) url += "?" + string.Join("&", qs);
        _items = (await Api.GetAsync<AppResult<List<SavedQuoteDto>>>(url))?.Data ?? new();
        _loaded = true;
    }

    private async Task Select(SavedQuoteDto item)
    {
        _selected = (await Api.GetAsync<AppResult<SavedQuoteDto>>($"api/properties/{PropertyId}/quotes/saved/{item.Id}"))?.Data ?? item;
    }

    private void OpenConvertModal(SavedQuoteDto item)
    {
        _quoteToConvert = item;
        _convertModalOpen = true;
        _converting = false;
        _convertError = null;
        _convertGuestResults = new();
        _convertGuestId = 0;
        _convertGuestSelectedName = string.Empty;
        _convertGuestQuery = item.GuestName ?? item.GuestEmail ?? item.GuestPhone ?? string.Empty;
        _quickGuestFullName = item.GuestName ?? string.Empty;
        _quickGuestPhone = item.GuestPhone;
        _quickGuestEmail = item.GuestEmail;
    }

    private void CloseConvertModal()
    {
        _convertModalOpen = false;
        _quoteToConvert = null;
        _convertError = null;
        _convertGuestResults = new();
        _convertGuestId = 0;
        _convertGuestSelectedName = string.Empty;
    }

    private async Task SearchGuestsForConvert(ChangeEventArgs e)
    {
        _convertGuestQuery = e.Value?.ToString() ?? string.Empty;
        _convertError = null;
        if (_convertGuestQuery.Trim().Length < 2)
        {
            _convertGuestResults = new();
            return;
        }

        var res = await Api.GetAsync<AppResult<List<GuestSearchItemDto>>>($"api/properties/{PropertyId}/guests/search?q={Uri.EscapeDataString(_convertGuestQuery.Trim())}");
        _convertGuestResults = res?.Data ?? new();
    }

    private void SelectConvertGuest(GuestSearchItemDto guest)
    {
        _convertGuestId = guest.Id;
        _convertGuestSelectedName = guest.FullName;
        _convertGuestQuery = guest.FullName;
        _convertGuestResults = new();
        _convertError = null;
    }

    private async Task CreateGuestForConvert()
    {
        _convertError = null;
        if (string.IsNullOrWhiteSpace(_quickGuestFullName))
        {
            _convertError = "Ingresá al menos el nombre completo para crear el huésped.";
            return;
        }

        var command = new UpsertGuestCommand(PropertyId, null, _quickGuestFullName.Trim(), _quickGuestPhone?.Trim(), _quickGuestEmail?.Trim(), null, null, null);
        var result = await Api.PostJsonAsync<AppResult<int>, UpsertGuestCommand>($"api/properties/{PropertyId}/guests", command);
        if (result?.Success != true || result.Data <= 0)
        {
            _convertError = result?.Message ?? "No se pudo crear el huésped.";
            return;
        }

        _convertGuestId = result.Data;
        _convertGuestSelectedName = _quickGuestFullName.Trim();
        _convertGuestQuery = _convertGuestSelectedName;
        _convertGuestResults = new();
    }

    private async Task ConfirmConvert()
    {
        if (_quoteToConvert is null || _convertGuestId <= 0)
            return;

        _converting = true;
        _convertError = null;
        var res = await Api.PostAsync<ConvertSavedQuoteToBookingCommand, AppResult<int>>($"api/properties/{PropertyId}/quotes/saved/{_quoteToConvert.Id}/convert", new ConvertSavedQuoteToBookingCommand(PropertyId, _quoteToConvert.Id, _convertGuestId, BookingStatus.Tentative, "Creada desde cotización guardada"));
        _converting = false;
        _success = res?.Success == true;
        _message = _success ? "Cotización convertida correctamente." : (res?.Message ?? "No se pudo convertir la cotización.");
        if (!_success)
        {
            _convertError = _message;
            return;
        }

        CloseConvertModal();
        await Load();
    }
}
